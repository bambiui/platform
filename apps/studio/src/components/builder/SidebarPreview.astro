---
import Button from "@bambiui/components/button/astro";
import Card from "@bambiui/components/card/astro";
import Sidebar from "@bambiui/components/sidebar/astro";

const usage = `<Sidebar side="left" collapsible="icon">
  <div class="bambi-sidebar-header">...</div>
  <div class="bambi-sidebar-content">...</div>
</Sidebar>`;
---
<Card class="card component-preview-card" id="card-sidebar-preview">
  <div class="cardHeader">
    <div>
      <h3>Sidebar</h3>
      <p class="component-description">Persistent navigation with groups, active state, disabled items, and collapse controls.</p>
    </div>
    <Button appearance="link" data-edit-card="sidebar-preview">Edit Tokens</Button>
  </div>

  <div class="control-grid" aria-label="Sidebar preview controls">
    <label>Side
      <select data-sidebar-control="side">
        <option value="left">Left</option>
        <option value="right">Right</option>
      </select>
    </label>
    <label>Collapsible
      <select data-sidebar-control="collapsible">
        <option value="icon">Icon</option>
        <option value="none">None</option>
      </select>
    </label>
    <label>Active item
      <select data-sidebar-control="active">
        <option value="overview">Overview</option>
        <option value="tokens">Tokens</option>
        <option value="components">Components</option>
      </select>
    </label>
  </div>

  <div class="preview-section">
    <span class="preview-section-label">Live preview</span>
    <div class="sidebar-stage">
      <Sidebar id="sidebar-live-preview" collapsible="icon" defaultOpen={true}>
        <div class="bambi-sidebar-header">
          <span class="brand-logo" aria-hidden="true"></span>
          <strong class="bambi-sidebar-label">Studio</strong>
        </div>
        <div class="bambi-sidebar-content">
          <div class="bambi-sidebar-group">
            <span class="bambi-sidebar-group-label">Workspace</span>
            <ul class="bambi-sidebar-menu">
              <li class="bambi-sidebar-menu-item"><a class="bambi-sidebar-menu-button" href="#card-sidebar-preview" data-preview-item="overview" data-active aria-current="page"><span>OV</span><span>Overview</span></a></li>
              <li class="bambi-sidebar-menu-item"><a class="bambi-sidebar-menu-button" href="#card-sidebar-preview" data-preview-item="tokens"><span>TK</span><span>Tokens</span></a></li>
              <li class="bambi-sidebar-menu-item"><a class="bambi-sidebar-menu-button" href="#card-sidebar-preview" data-preview-item="components"><span>CP</span><span>Components</span></a></li>
              <li class="bambi-sidebar-menu-item"><button class="bambi-sidebar-menu-button" type="button" data-disabled disabled><span>AR</span><span>Archive</span></button></li>
            </ul>
          </div>
          <div class="bambi-sidebar-group">
            <span class="bambi-sidebar-group-label">Views</span>
            <ul class="bambi-sidebar-menu">
              <li class="bambi-sidebar-menu-item"><a class="bambi-sidebar-menu-button" href="#card-sidebar-preview"><span>DB</span><span>Dashboard</span></a></li>
            </ul>
          </div>
        </div>
        <div class="bambi-sidebar-footer">
          <span class="brand-logo" aria-hidden="true"></span>
          <span class="bambi-sidebar-label">Theme ready</span>
        </div>
      </Sidebar>
      <div class="sidebar-canvas">
        <Card variant="outline" class="sidebar-content-card">
          <div class="bambi-card-header">
            <h4 class="bambi-card-title">Main content</h4>
            <p class="bambi-card-description">The sidebar stays semantic and does not trap focus.</p>
          </div>
        </Card>
      </div>
    </div>
  </div>

  <pre class="usage-snippet"><code>{usage}</code></pre>
</Card>
