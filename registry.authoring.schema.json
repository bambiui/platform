{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bambiui.com/registry.authoring.schema.json",
  "title": "bambiui authoring registry v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "components"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "const": 1 },
    "components": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/component" }
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "contract", "controller", "style", "generatedFiles", "exports"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "contract": { "$ref": "#/$defs/registryPath" },
        "contractFiles": { "$ref": "#/$defs/registryFileList" },
        "primitiveFiles": { "$ref": "#/$defs/registryFileList" },
        "controller": { "$ref": "#/$defs/registryPath" },
        "style": { "$ref": "#/$defs/registryPath" },
        "generatedCss": { "$ref": "#/$defs/registryPath" },
        "generatedFiles": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "react": { "$ref": "#/$defs/registryFileList" },
            "solid": { "$ref": "#/$defs/registryFileList" },
            "svelte": { "$ref": "#/$defs/registryFileList" },
            "vue": { "$ref": "#/$defs/registryFileList" }
          }
        },
        "generator": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/generatorOptions" },
          "properties": {
            "react": { "$ref": "#/$defs/generatorOptions" },
            "solid": { "$ref": "#/$defs/generatorOptions" },
            "svelte": { "$ref": "#/$defs/generatorOptions" },
            "vue": { "$ref": "#/$defs/generatorOptions" }
          }
        },
        "exports": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "react": { "$ref": "#/$defs/exportNames" },
            "solid": { "$ref": "#/$defs/exportNames" },
            "svelte": { "$ref": "#/$defs/exportNames" },
            "vue": { "$ref": "#/$defs/exportNames" }
          }
        }
      }
    },
    "registryFileList": {
      "type": "array",
      "items": { "$ref": "#/$defs/registryPath" }
    },
    "exportNames": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "generatorOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "valuePropName": {
          "type": "string",
          "minLength": 1
        },
        "valuePropParts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "disabledPropName": {
          "type": "string",
          "minLength": 1
        },
        "disabledPropParts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "registryPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+"
    }
  }
}
