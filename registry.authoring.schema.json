{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bambiui.com/registry.authoring.schema.json",
  "title": "bambiui authoring registry v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "components"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "const": 1 },
    "components": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/component" }
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "contract", "controller", "style", "generatedCss", "generatedFiles", "exports"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "contract": { "$ref": "#/$defs/registryPath" },
        "contractFiles": { "$ref": "#/$defs/registryFileList" },
        "primitiveFiles": { "$ref": "#/$defs/registryFileList" },
        "controller": { "$ref": "#/$defs/registryPath" },
        "style": { "$ref": "#/$defs/registryPath" },
        "generatedCss": { "$ref": "#/$defs/registryPath" },
        "generatedFiles": {
          "type": "object",
          "additionalProperties": false,
          "required": ["react", "solid", "svelte", "vue"],
          "properties": {
            "react": { "$ref": "#/$defs/registryFileList" },
            "solid": { "$ref": "#/$defs/registryFileList" },
            "svelte": { "$ref": "#/$defs/registryFileList" },
            "vue": { "$ref": "#/$defs/registryFileList" }
          }
        },
        "generator": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "react": { "$ref": "#/$defs/generatorOptions" },
            "solid": { "$ref": "#/$defs/generatorOptions" },
            "svelte": { "$ref": "#/$defs/generatorOptions" },
            "vue": { "$ref": "#/$defs/generatorOptions" }
          }
        },
        "exports": {
          "type": "object",
          "additionalProperties": false,
          "required": ["react", "solid", "svelte", "vue"],
          "properties": {
            "react": { "$ref": "#/$defs/exportNames" },
            "solid": { "$ref": "#/$defs/exportNames" },
            "svelte": { "$ref": "#/$defs/exportNames" },
            "vue": { "$ref": "#/$defs/exportNames" }
          }
        }
      }
    },
    "registryFileList": {
      "type": "array",
      "items": { "$ref": "#/$defs/registryPath" },
      "minItems": 1
    },
    "exportNames": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "generatorOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "valuePropName": {
          "type": "string",
          "minLength": 1
        },
        "valuePropParts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "disabledPropName": {
          "type": "string",
          "minLength": 1
        },
        "disabledPropParts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "polymorphicRootPropName": {
          "type": "string",
          "minLength": 1
        },
        "polymorphicNativeElement": {
          "type": "string",
          "minLength": 1
        },
        "polymorphicTypeDefault": {
          "type": "string",
          "minLength": 1
        },
        "defaultTypeParts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "defaultTypeValue": {
          "type": "string",
          "minLength": 1
        },
        "defaultTypeValues": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "ssrSelectedState": {
          "type": "object",
          "additionalProperties": false,
          "required": ["selectedPropNames", "valuePropName", "contextName", "parts"],
          "properties": {
            "selectedPropNames": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1
            },
            "valuePropName": {
              "type": "string",
              "minLength": 1
            },
            "contextName": {
              "type": "string",
              "minLength": 1
            },
            "parts": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "additionalProperties": false,
                "required": ["attributes"],
                "properties": {
                  "attributes": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/ssrSelectedAttribute" },
                    "minItems": 1
                  }
                }
              },
              "minProperties": 1
            }
          }
        },
        "embeddedParts": {
          "type": "array",
          "items": { "$ref": "#/$defs/embeddedPart" },
          "minItems": 1
        }
      }
    },
    "embeddedPart": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parentPartName", "childPartName"],
      "properties": {
        "parentPartName": { "type": "string", "minLength": 1 },
        "childPartName": { "type": "string", "minLength": 1 },
        "omitChildComponent": { "type": "boolean" },
        "attributes": {
          "type": "array",
          "items": { "$ref": "#/$defs/embeddedPartAttribute" }
        }
      }
    },
    "embeddedPartAttribute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "reactName": { "type": "string", "minLength": 1 },
        "solidName": { "type": "string", "minLength": 1 },
        "svelteName": { "type": "string", "minLength": 1 },
        "vueName": { "type": "string", "minLength": 1 },
        "propName": { "type": "string", "minLength": 1 },
        "selected": { "type": "boolean" },
        "value": {
          "anyOf": [{ "type": "string" }, { "type": "number" }, { "type": "boolean" }]
        }
      }
    },
    "ssrSelectedAttribute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "reactName": { "type": "string", "minLength": 1 },
        "solidName": { "type": "string", "minLength": 1 },
        "svelteName": { "type": "string", "minLength": 1 },
        "vueName": { "type": "string", "minLength": 1 },
        "value": {
          "anyOf": [{ "type": "string" }, { "type": "number" }, { "type": "boolean" }]
        },
        "active": {
          "anyOf": [{ "type": "string" }, { "type": "number" }, { "type": "boolean" }]
        },
        "inactive": {
          "anyOf": [{ "type": "string" }, { "type": "number" }, { "type": "boolean" }]
        }
      }
    },
    "registryPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+"
    }
  }
}
