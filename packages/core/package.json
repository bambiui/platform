{
  "name": "@bambiui/core",
  "version": "0.1.0",
  "description": "Framework-agnostic DOM protocol types and utilities for bambiui.",
  "license": "MIT",
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./dom/controller": {
      "types": "./src/dom/controller.ts",
      "import": "./src/dom/controller.ts",
      "default": "./src/dom/controller.ts"
    },
    "./dom/events": {
      "types": "./src/dom/events.ts",
      "import": "./src/dom/events.ts",
      "default": "./src/dom/events.ts"
    },
    "./dom/attributes": {
      "types": "./src/dom/attributes.ts",
      "import": "./src/dom/attributes.ts",
      "default": "./src/dom/attributes.ts"
    },
    "./dom/mount": {
      "types": "./src/dom/mount.ts",
      "import": "./src/dom/mount.ts",
      "default": "./src/dom/mount.ts"
    },
    "./components/tabs": {
      "types": "./src/components/tabs/index.ts",
      "import": "./src/components/tabs/index.ts",
      "default": "./src/components/tabs/index.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit --strict --moduleResolution bundler --module ESNext --target ES2022 src/index.ts"
  }
}
