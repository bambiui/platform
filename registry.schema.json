{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bambiui.com/registry.schema.json",
  "title": "bambiui registry v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "styles", "components"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "const": 2
    },
    "styles": {
      "type": "object",
      "additionalProperties": false,
      "required": ["global"],
      "properties": {
        "global": {
          "$ref": "#/$defs/registryPath"
        }
      }
    },
    "components": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/component"
      }
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "contract", "controller", "style", "files"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "contract": {
          "$ref": "#/$defs/registryPath"
        },
        "controller": {
          "$ref": "#/$defs/registryPath"
        },
        "style": {
          "$ref": "#/$defs/registryPath"
        },
        "files": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "react": {
              "$ref": "#/$defs/frameworkFiles"
            },
            "vue": {
              "$ref": "#/$defs/frameworkFiles"
            },
            "svelte": {
              "$ref": "#/$defs/frameworkFiles"
            },
            "solid": {
              "$ref": "#/$defs/frameworkFiles"
            },
            "html": {
              "$ref": "#/$defs/frameworkFiles"
            }
          }
        }
      }
    },
    "frameworkFiles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/registryPath"
      }
    },
    "registryPath": {
      "type": "string",
      "minLength": 1
    }
  }
}
