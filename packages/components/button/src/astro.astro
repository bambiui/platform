---
import { buttonRecipe } from "./recipe";
import type { ButtonBaseProps } from "./types";
import "./button.css";

interface Props extends ButtonBaseProps {
  class?: string;
  disabled?: boolean;
  id?: string;
  type?: "button" | "submit" | "reset";
  [key: string]: unknown;
}

const astro = Astro as unknown as { props: Props };

const {
  intent = buttonRecipe.defaults.intent,
  appearance = buttonRecipe.defaults.appearance,
  size = buttonRecipe.defaults.size,
  loading = buttonRecipe.defaults.loading,
  type = "button",
  class: className,
  disabled,
  ...attrs
} = astro.props;

const cls = [buttonRecipe.className, className].filter(Boolean).join(" ");
const isLoading = Boolean(loading);
const isDisabled = Boolean(disabled || isLoading);
---
<button
  {...attrs}
  type={type}
  class={cls}
  data-intent={intent}
  data-appearance={appearance}
  data-size={size}
  data-loading={isLoading || undefined}
  aria-busy={isLoading || undefined}
  aria-disabled={isDisabled || undefined}
  disabled={isDisabled}
>
  {isLoading && <span class="bambi-button-spinner" aria-hidden="true" />}
  <span class="bambi-button-content"><slot /></span>
</button>
