{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bambiui.com/registry.schema.json",
  "title": "bambiui registry v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "styles", "components"],
  "dependentRequired": {
    "shared": ["sharedHash"]
  },
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "const": 2 },
    "styles": {
      "type": "object",
      "additionalProperties": false,
      "required": ["global", "globalHash"],
      "properties": {
        "global": { "$ref": "#/$defs/registryPath" },
        "globalHash": { "$ref": "#/$defs/sha256Hex" }
      }
    },
    "shared": { "$ref": "#/$defs/registryPath" },
    "sharedHash": { "$ref": "#/$defs/sha256Hex" },
    "components": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/component" }
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "files", "exports", "hashes"],
      "dependentRequired": {
        "css": ["cssHash"]
      },
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "css": { "$ref": "#/$defs/registryPath" },
        "cssHash": { "$ref": "#/$defs/sha256Hex" },
        "files": {
          "type": "object",
          "additionalProperties": false,
          "required": ["react", "solid", "svelte", "vue"],
          "properties": {
            "react": { "$ref": "#/$defs/registryFileList" },
            "solid": { "$ref": "#/$defs/registryFileList" },
            "svelte": { "$ref": "#/$defs/registryFileList" },
            "vue": { "$ref": "#/$defs/registryFileList" }
          }
        },
        "helpers": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "react": { "$ref": "#/$defs/exportNames" },
            "solid": { "$ref": "#/$defs/exportNames" },
            "svelte": { "$ref": "#/$defs/exportNames" },
            "vue": { "$ref": "#/$defs/exportNames" }
          }
        },
        "hashes": {
          "type": "object",
          "additionalProperties": false,
          "required": ["react", "solid", "svelte", "vue"],
          "properties": {
            "react": { "$ref": "#/$defs/frameworkHashes" },
            "solid": { "$ref": "#/$defs/frameworkHashes" },
            "svelte": { "$ref": "#/$defs/frameworkHashes" },
            "vue": { "$ref": "#/$defs/frameworkHashes" }
          }
        },
        "exports": {
          "type": "object",
          "additionalProperties": false,
          "required": ["react", "solid", "svelte", "vue"],
          "properties": {
            "react": { "$ref": "#/$defs/exportNames" },
            "solid": { "$ref": "#/$defs/exportNames" },
            "svelte": { "$ref": "#/$defs/exportNames" },
            "vue": { "$ref": "#/$defs/exportNames" }
          }
        }
      }
    },
    "frameworkHashes": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/sha256Hex" }
    },
    "registryFileList": {
      "type": "array",
      "items": { "$ref": "#/$defs/registryPath" },
      "minItems": 1
    },
    "exportNames": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "registryPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+"
    },
    "sha256Hex": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
