---
---
<aside id="drawer-left">
  <a href="/" class="drawer-brand">
    <svg width="48" height="48" viewBox="0 0 576 560" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M6.10352e-05 490.342V100.342C6.10352e-05 45.3418 7.00006 8.34176 30.0001 1.34176C65.0001 -9.35824 148 45.3418 189 115.342C219 111.342 253 109.342 287.5 109.342C322 109.342 356 111.342 386 115.342C427 45.3418 510 -9.35824 545 1.34176C568 8.34176 575 45.3418 575 100.342V490.342C575 533.342 548 559.342 505 559.342H70.0001C27.0001 559.342 6.10352e-05 533.342 6.10352e-05 490.342Z" fill="#617DFF"/>
      <path d="M246.366 137.842C263 118.842 290.317 116.994 310.794 137.842C340.261 167.842 356.743 228.842 394.701 266.842C432.658 304.842 575 381.605 575 410.842C575 425.842 575.624 453.347 575 489.842C574 548.342 532.5 559.342 502.581 559.342C502.581 559.342 127 560.342 70 559.342C13.0001 558.342 6.28285e-05 518.842 2.265e-05 490.342C-1.75284e-05 461.842 7.9873e-06 355.842 7.9873e-06 355.842C3.99556 322.842 110.517 372.342 169.451 389.342C219.895 397.842 244.867 395.842 259.851 334.842C273.835 278.842 199.418 208.342 246.366 137.842Z" fill="white" fill-opacity="0.75"/>
      <path d="M392.5 425.842C403.546 425.842 412.5 416.887 412.5 405.842C412.5 394.796 403.546 385.842 392.5 385.842C381.454 385.842 372.5 394.796 372.5 405.842C372.5 416.887 381.454 425.842 392.5 425.842Z" fill="#617DFF"/>
    </svg>
    <span class="brand-name">bambiui</span>
  </a>

  <div class="drawer-section-label">Frames</div>
  <nav class="drawer-nav">
    <button class="nav-item" data-card="colors">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <circle cx="8" cy="8" r="6.25" stroke="currentColor" stroke-width="1.5"></circle>
        <circle cx="5" cy="7" r="1.5" fill="currentColor"></circle>
        <circle cx="11" cy="7" r="1.5" fill="currentColor"></circle>
        <circle cx="8" cy="11" r="1.5" fill="currentColor"></circle>
      </svg>
      Colors
    </button>
    <button class="nav-item" data-card="typography">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M2.5 4h11M8 4v8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
      </svg>
      Typography
    </button>
    <button class="nav-item" data-card="buttons">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <rect x="1.75" y="5" width="12.5" height="6" rx="2" stroke="currentColor" stroke-width="1.5"></rect>
      </svg>
      Buttons
    </button>
  </nav>

  <div class="drawer-footer">
    <span class="drawer-footer-label">Theme</span>
    <div class="theme-switcher">
      <button class="theme-btn active" data-theme-val="light">
        <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="8" cy="8" r="3" stroke="currentColor" stroke-width="1.5"></circle>
          <path d="M8 1v2M8 13v2M1 8h2M13 8h2M3.05 3.05l1.41 1.41M11.54 11.54l1.41 1.41M3.05 12.95l1.41-1.41M11.54 4.46l1.41-1.41" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
        </svg>
        Light
      </button>
      <button class="theme-btn" data-theme-val="dark">
        <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M13.5 10.5A6 6 0 015.5 2.5a6 6 0 000 11 6 6 0 008-3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path>
        </svg>
        Dark
      </button>
    </div>
  </div>
</aside>
