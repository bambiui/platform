{
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "@bambiui/core": ["../core/src/index.ts"],
      "@bambiui/core/*": ["../core/src/*"]
    },
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022"
  },
  "include": [
    "src-env.d.ts",
    "button/src/**/*.astro",
    "button/src/**/*.svelte",
    "button/src/**/*.ts",
    "button/src/**/*.tsx",
    "button/src/**/*.vue"
  ]
}
