{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "include": ["src", "generated"],
  "exclude": [
    "generated/*/solid",
    "generated/*/svelte",
    "generated/*/vue"
  ]
}
