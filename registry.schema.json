{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bambi-ui.felekoglu.dev/registry.schema.json",
  "title": "BambiUI Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "tokens", "components"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "tokens": {
      "type": "object",
      "additionalProperties": false,
      "required": ["css"],
      "properties": {
        "css": {
          "$ref": "#/$defs/registryPath"
        }
      }
    },
    "components": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/component"
      }
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exportName", "api", "style", "shared", "files"],
      "properties": {
        "exportName": {
          "$ref": "#/$defs/exportName"
        },
        "api": {
          "$ref": "#/$defs/componentApi"
        },
        "style": {
          "$ref": "#/$defs/styleFile"
        },
        "shared": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/registryFile"
          }
        },
        "files": {
          "type": "object",
          "additionalProperties": false,
          "required": ["react", "svelte", "vue", "astro"],
          "properties": {
            "react": {
              "$ref": "#/$defs/frameworkFiles"
            },
            "svelte": {
              "$ref": "#/$defs/frameworkFiles"
            },
            "vue": {
              "$ref": "#/$defs/frameworkFiles"
            },
            "astro": {
              "$ref": "#/$defs/frameworkFiles"
            }
          }
        }
      }
    },
    "componentApi": {
      "type": "object",
      "additionalProperties": false,
      "required": ["typeExports"],
      "properties": {
        "typeExports": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/exportName"
          },
          "uniqueItems": true
        },
        "types": {
          "$ref": "#/$defs/generatedTypes"
        }
      }
    },
    "generatedTypes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "consts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "values"],
            "properties": {
              "name": {
                "$ref": "#/$defs/exportName"
              },
              "values": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "minItems": 1
              }
            }
          }
        },
        "aliasesFromConsts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "constName"],
            "properties": {
              "name": {
                "$ref": "#/$defs/exportName"
              },
              "constName": {
                "$ref": "#/$defs/exportName"
              }
            }
          }
        },
        "interfaces": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "props"],
            "properties": {
              "name": {
                "$ref": "#/$defs/exportName"
              },
              "props": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["name", "type"],
                  "properties": {
                    "name": {
                      "$ref": "#/$defs/propertyName"
                    },
                    "type": {
                      "type": "string"
                    },
                    "optional": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          }
        },
        "requiredPicks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "source", "keys"],
            "properties": {
              "name": {
                "$ref": "#/$defs/exportName"
              },
              "source": {
                "$ref": "#/$defs/exportName"
              },
              "keys": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/propertyName"
                },
                "minItems": 1
              }
            }
          }
        }
      }
    },
    "styleFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "fileName"],
      "properties": {
        "from": {
          "$ref": "#/$defs/registryPath"
        },
        "fileName": {
          "$ref": "#/$defs/fileName"
        }
      }
    },
    "frameworkFiles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/registryFile"
      },
      "minItems": 1
    },
    "registryFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "to"],
      "properties": {
        "kind": {
          "$ref": "#/$defs/kind"
        },
        "from": {
          "$ref": "#/$defs/registryPath"
        },
        "to": {
          "$ref": "#/$defs/fileName"
        },
        "generate": {
          "enum": ["types"]
        }
      },
      "oneOf": [
        {
          "required": ["from"]
        },
        {
          "required": ["generate"]
        }
      ]
    },
    "kind": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "exportName": {
      "type": "string",
      "pattern": "^[A-Za-z_$][A-Za-z0-9_$]*$"
    },
    "propertyName": {
      "type": "string",
      "pattern": "^[A-Za-z_$][A-Za-z0-9_$]*$"
    },
    "fileName": {
      "type": "string",
      "pattern": "^[^/]+$"
    },
    "registryPath": {
      "type": "string",
      "minLength": 1
    }
  }
}
