---
import "@bambiui/tokens/tokens.css";
import "../styles/builder.css";
import { colorGroups, typeSizes, typeWeights } from "../data/builderData";
import DrawerLeft from "../components/builder/DrawerLeft.astro";
import DrawerRight from "../components/builder/DrawerRight.astro";
import CardColors from "../components/builder/CardColors.astro";
import CardTypography from "../components/builder/CardTypography.astro";
import CardButtons from "../components/builder/CardButtons.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/builder/favicon.svg" type="image/svg+xml" />
    <title>Builder</title>
    <script is:inline>
      (function () {
        var s = localStorage.getItem("starlight-theme");
        var dark = s === "dark" || (s !== "light" && window.matchMedia("(prefers-color-scheme: dark)").matches);
        document.documentElement.setAttribute("data-theme", dark ? "dark" : "light");
        if (dark) document.documentElement.classList.add("dark");
      })();
    </script>
  </head>
  <body>
    <DrawerLeft />
    <DrawerRight />
    <div id="canvas">
      <div id="canvas-transform">
        <CardColors colorGroups={colorGroups} />
        <CardTypography typeSizes={typeSizes} typeWeights={typeWeights} />
        <CardButtons />
      </div>
    </div>
    <script src="../scripts/builder.ts"></script>
  </body>
</html>
