{
  "name": "bambiui",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "deploy-static": "turbo run build && mkdir -p apps/docs/dist/builder && cp -r apps/builder/dist/. apps/docs/dist/builder/",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.9",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
