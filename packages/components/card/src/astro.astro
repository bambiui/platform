---
import { cardRecipe } from "./recipe";
import type { CardBaseProps } from "./types";
import "./card.css";

interface Props extends CardBaseProps {
  class?: string;
  id?: string;
  title?: string;
  description?: string;
  [key: string]: unknown;
}

const astro = Astro as unknown as { props: Props };

const {
  variant = cardRecipe.defaults.variant,
  size = cardRecipe.defaults.size,
  interactive = cardRecipe.defaults.interactive,
  title,
  description,
  class: className,
  ...attrs
} = astro.props;

const cls = [cardRecipe.className, className].filter(Boolean).join(" ");
const hasHeader = Astro.slots.has("header") || Boolean(title || description);
const hasFooter = Astro.slots.has("footer") || Astro.slots.has("actions");
---
<div
  {...attrs}
  class={cls}
  data-variant={variant}
  data-size={size}
  data-interactive={interactive || undefined}
>
  {hasHeader && (
    <div class="bambi-card-header">
      {Astro.slots.has("header") ? (
        <slot name="header" />
      ) : (
        <>
          {title && <h3 class="bambi-card-title">{title}</h3>}
          {description && <p class="bambi-card-description">{description}</p>}
        </>
      )}
    </div>
  )}
  {hasHeader || hasFooter ? (
    <div class="bambi-card-content"><slot /></div>
  ) : (
    <slot />
  )}
  {hasFooter && (
    <div class="bambi-card-footer">
      {Astro.slots.has("footer") ? <slot name="footer" /> : <slot name="actions" />}
    </div>
  )}
</div>
