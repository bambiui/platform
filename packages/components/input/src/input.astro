---
import { inputRecipe } from "./recipe";
import "./input.css";

interface Props {
  class?: string;
  id?: string;
  type?: string;
  name?: string;
  value?: string | number;
  placeholder?: string;
  disabled?: boolean;
  readonly?: boolean;
  required?: boolean;
  autocomplete?: string;
  /** Marks the input as invalid; sets aria-invalid="true". */
  invalid?: boolean;
  "aria-label"?: string;
  "aria-describedby"?: string;
  "aria-invalid"?: string | boolean;
  [key: string]: unknown;
}

const astro = Astro as unknown as { props: Props };

const {
  class: className,
  invalid,
  id,
  "aria-describedby": ariaDescribedBy,
  "aria-invalid": ariaInvalidProp,
  ...attrs
} = astro.props;

const resolvedInvalid =
  ariaInvalidProp !== undefined ? ariaInvalidProp : invalid ? "true" : undefined;

const cls = [inputRecipe.elementClassName, className].filter(Boolean).join(" ");
---

<input
  {...attrs}
  id={id}
  class={cls}
  aria-describedby={ariaDescribedBy}
  aria-invalid={resolvedInvalid}
/>
