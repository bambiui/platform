{
  "name": "@bambiui/core",
  "version": "0.0.1",
  "description": "Framework-agnostic contracts and utilities for bambiui.",
  "license": "MIT",
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./contracts": {
      "types": "./src/contracts.ts",
      "import": "./src/contracts.ts",
      "default": "./src/contracts.ts"
    },
    "./button": {
      "types": "./src/button.ts",
      "import": "./src/button.ts",
      "default": "./src/button.ts"
    },
    "./buttongroup": {
      "types": "./src/buttongroup.ts",
      "import": "./src/buttongroup.ts",
      "default": "./src/buttongroup.ts"
    },
    "./card": {
      "types": "./src/card.ts",
      "import": "./src/card.ts",
      "default": "./src/card.ts"
    },
    "./sidebar": {
      "types": "./src/sidebar.ts",
      "import": "./src/sidebar.ts",
      "default": "./src/sidebar.ts"
    },
    "./drawer": {
      "types": "./src/drawer.ts",
      "import": "./src/drawer.ts",
      "default": "./src/drawer.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit --strict --moduleResolution bundler --module ESNext --target ES2022 src/index.ts"
  }
}
