---
import { buttonGroupRecipe } from "./recipe";
import type { ButtonGroupBaseProps } from "./types";
import "./buttongroup.css";

interface Props extends ButtonGroupBaseProps {
  class?: string;
  id?: string;
  role?: string;
  [key: string]: unknown;
}

const astro = Astro as unknown as { props: Props };

const {
  orientation = buttonGroupRecipe.defaults.orientation,
  attached = buttonGroupRecipe.defaults.attached,
  role = "group",
  class: className,
  ...attrs
} = astro.props;

const cls = [buttonGroupRecipe.className, className].filter(Boolean).join(" ");
---
<div
  role={role}
  class={cls}
  data-orientation={orientation}
  data-attached={attached || undefined}
  {...attrs}
>
  <slot />
</div>
