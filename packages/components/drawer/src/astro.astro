---
import { drawerRecipe } from "./recipe";
import type { DrawerBaseProps } from "./types";
import "./drawer.css";

interface Props extends DrawerBaseProps {
  class?: string;
  id?: string;
  title?: string;
  description?: string;
  [key: string]: unknown;
}

const astro = Astro as unknown as { props: Props };

const {
  side = drawerRecipe.defaults.side,
  size = drawerRecipe.defaults.size,
  defaultOpen = drawerRecipe.defaults.defaultOpen,
  closeOnOverlayClick = drawerRecipe.defaults.closeOnOverlayClick,
  title,
  description,
  class: className,
  id,
  ...attrs
} = astro.props;

const drawerId = id ?? `bambi-drawer-${Math.random().toString(36).slice(2, 7)}`;
const titleId = `${drawerId}-title`;
const descId = `${drawerId}-desc`;
const initialState = defaultOpen ? "open" : "closed";
const hasConvenienceContent = Boolean(title || description) || Astro.slots.has("footer");
---

<div
  id={drawerId}
  class="bambi-drawer-root"
  data-close-on-overlay-click={closeOnOverlayClick}
>
  <div
    class="bambi-drawer-overlay"
    data-state={initialState}
    aria-hidden="true"
    data-drawer-overlay={drawerId}
  ></div>
  <div
    {...attrs}
    class={["bambi-drawer-content", className].filter(Boolean).join(" ")}
    role="dialog"
    aria-modal="true"
    aria-labelledby={titleId}
    aria-describedby={descId}
    tabindex="-1"
    data-state={initialState}
    data-side={side}
    data-size={size}
    data-drawer-content={drawerId}
  >
    <button
      type="button"
      class="bambi-drawer-close"
      aria-label="Close"
      data-drawer-close={drawerId}
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path
          d="M12 4L4 12M4 4l8 8"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
        />
      </svg>
    </button>
    {(title || description) && (
      <div class="bambi-drawer-header">
        {title && <h2 id={titleId} class="bambi-drawer-title">{title}</h2>}
        {description && <p id={descId} class="bambi-drawer-description">{description}</p>}
      </div>
    )}
    {hasConvenienceContent ? (
      <div class="bambi-drawer-body"><slot /></div>
    ) : (
      <slot />
    )}
    {Astro.slots.has("footer") && (
      <div class="bambi-drawer-footer"><slot name="footer" /></div>
    )}
  </div>
</div>

<script>
  const FOCUSABLE =
    'a[href],button:not([disabled]),textarea:not([disabled]),input:not([disabled]),select:not([disabled]),[tabindex]:not([tabindex="-1"])';

  function openDrawer(drawerId: string) {
    const root = document.getElementById(drawerId);
    if (!root) return;
    const overlay = root.querySelector<HTMLElement>("[data-drawer-overlay]");
    const content = root.querySelector<HTMLElement>("[data-drawer-content]");
    if (!overlay || !content) return;

    overlay.dataset.state = "open";
    content.dataset.state = "open";

    // Scroll lock
    const scrollY = window.scrollY;
    const pad = window.innerWidth - document.documentElement.clientWidth;
    document.body.style.overflow = "hidden";
    if (pad > 0) document.body.style.paddingRight = `${pad}px`;
    (root as HTMLElement & { _scrollY?: number })._scrollY = scrollY;

    // Inert background
    Array.from(document.body.children).forEach((el) => {
      if (el !== root && !root.contains(el)) el.setAttribute("inert", "");
    });

    // Focus first element
    const first = content.querySelector<HTMLElement>(FOCUSABLE);
    setTimeout(() => first?.focus(), 0);
  }

  function closeDrawer(drawerId: string, triggerEl?: HTMLElement | null) {
    const root = document.getElementById(drawerId);
    if (!root) return;
    const overlay = root.querySelector<HTMLElement>("[data-drawer-overlay]");
    const content = root.querySelector<HTMLElement>("[data-drawer-content]");
    if (!overlay || !content) return;

    overlay.dataset.state = "closed";
    content.dataset.state = "closed";

    // Restore scroll
    const scrollY = (root as HTMLElement & { _scrollY?: number })._scrollY ?? 0;
    document.body.style.overflow = "";
    document.body.style.paddingRight = "";
    window.scrollTo(0, scrollY);

    // Remove inert
    Array.from(document.body.children).forEach((el) => el.removeAttribute("inert"));

    // Restore focus
    triggerEl?.focus();
  }

  // Wire triggers
  document.querySelectorAll<HTMLElement>("[data-drawer-open]").forEach((btn) => {
    const drawerId = btn.dataset.drawerOpen!;
    btn.addEventListener("click", () => openDrawer(drawerId));
  });

  // Wire close buttons
  document.querySelectorAll<HTMLElement>("[data-drawer-close]").forEach((btn) => {
    const drawerId = btn.dataset.drawerClose!;
    const trigger = document.querySelector<HTMLElement>(`[data-drawer-open="${drawerId}"]`);
    btn.addEventListener("click", () => closeDrawer(drawerId, trigger));
  });

  // Wire overlays
  document.querySelectorAll<HTMLElement>("[data-drawer-overlay]").forEach((overlay) => {
    const drawerId = overlay.dataset.drawerOverlay!;
    const root = document.getElementById(drawerId);
    if (!root) return;
    const closeOnClick = root.dataset.closeOnOverlayClick !== "false";
    if (!closeOnClick) return;
    const trigger = document.querySelector<HTMLElement>(`[data-drawer-open="${drawerId}"]`);
    overlay.addEventListener("click", () => closeDrawer(drawerId, trigger));
  });

  // Escape key
  document.addEventListener("keydown", (e) => {
    if (e.key !== "Escape" && e.key !== "Tab") return;
    const openContent = document.querySelector<HTMLElement>(
      "[data-drawer-content][data-state='open']",
    );
    if (!openContent) return;

    if (e.key === "Escape") {
      const drawerId = openContent.dataset.drawerContent!;
      const trigger = document.querySelector<HTMLElement>(`[data-drawer-open="${drawerId}"]`);
      closeDrawer(drawerId, trigger);
      return;
    }

    // Focus trap
    const els = Array.from(openContent.querySelectorAll<HTMLElement>(FOCUSABLE));
    if (!els.length) return;
    const first = els[0];
    const last = els[els.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) {
        e.preventDefault();
        last.focus();
      }
    } else {
      if (document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  });
</script>
