{
  "name": "@bambi-ui/button",
  "version": "0.0.1",
  "description": "Shared types and base for bambi-ui Button — framework-agnostic core",
  "keywords": ["bambi-ui", "button", "types", "typescript"],
  "private": false,
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./index.css": "./src/index.css"
  },
  "sideEffects": ["**/*.css"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  },
  "files": ["dist", "src/index.css"]
}
