{
  "name": "@bambiui/core",
  "version": "0.1.0",
  "description": "Framework-agnostic DOM protocol types and utilities for bambiui.",
  "license": "MIT",
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./dom/controller": {
      "types": "./src/dom/controller.ts",
      "import": "./src/dom/controller.ts",
      "default": "./src/dom/controller.ts"
    },
    "./dom/events": {
      "types": "./src/dom/events.ts",
      "import": "./src/dom/events.ts",
      "default": "./src/dom/events.ts"
    },
    "./dom/attributes": {
      "types": "./src/dom/attributes.ts",
      "import": "./src/dom/attributes.ts",
      "default": "./src/dom/attributes.ts"
    },
    "./dom/mount": {
      "types": "./src/dom/mount.ts",
      "import": "./src/dom/mount.ts",
      "default": "./src/dom/mount.ts"
    },
    "./contract": {
      "types": "./contract/index.ts",
      "import": "./contract/index.ts",
      "default": "./contract/index.ts"
    },
    "./runtime": {
      "types": "./runtime/index.ts",
      "import": "./runtime/index.ts",
      "default": "./runtime/index.ts"
    },
    "./tabs/tabs.contract": {
      "types": "./tabs/tabs.contract.ts",
      "import": "./tabs/tabs.contract.ts",
      "default": "./tabs/tabs.contract.ts"
    },
    "./components/tabs": {
      "types": "./src/components/tabs/index.ts",
      "import": "./src/components/tabs/index.ts",
      "default": "./src/components/tabs/index.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit --strict --moduleResolution bundler --module ESNext --target ES2022 src/index.ts contract/index.ts runtime/index.ts tabs/tabs.contract.ts",
    "test:tabs": "node scripts/test-tabs-controller.mjs",
    "test:roving-focus": "node scripts/test-roving-focus.mjs"
  }
}
