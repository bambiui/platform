{
  "name": "@bambiui/workspace",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:static": "pnpm registry:refresh && node scripts/build-static.mjs",
    "check": "pnpm registry:refresh && pnpm check-types && pnpm check-registry && pnpm check-boundaries && pnpm --filter @bambiui/core test:tabs && pnpm --filter @bambiui/core test:radio-group && pnpm --filter @bambiui/core test:roving-focus && pnpm --filter @bambiui/generator test && pnpm --filter bambiui smoke",
    "check:full": "pnpm check && pnpm smoke:templates -- --install",
    "check-boundaries": "node scripts/check-package-boundaries.mjs",
    "check-registry": "node scripts/check-registry.mjs",
    "registry:refresh": "node scripts/registry-refresh.mjs",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "smoke:templates": "node scripts/smoke-templates.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@bambiui/generator": "workspace:*",
    "ajv": "^8.20.0",
    "prettier": "^3.7.4",
    "turbo": "^2.9.9",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22.12.0"
  }
}
