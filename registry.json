{
  "$schema": "https://bambi-ui.felekoglu.dev/registry.schema.json",
  "version": 1,
  "tokens": {
    "css": "packages/tokens/src/tokens.css"
  },
  "components": {
    "button": {
      "exportName": "Button",
      "api": {
        "typeExports": [
          "ButtonAppearance",
          "ButtonBaseProps",
          "ButtonIntent",
          "ButtonSize"
        ],
        "types": {
          "consts": [
            {
              "name": "buttonIntents",
              "values": ["primary", "secondary", "danger", "success", "warning"]
            },
            {
              "name": "buttonAppearances",
              "values": ["solid", "outline", "ghost", "link"]
            },
            {
              "name": "buttonSizes",
              "values": ["sm", "md", "lg", "icon"]
            }
          ],
          "aliasesFromConsts": [
            {
              "name": "ButtonIntent",
              "constName": "buttonIntents"
            },
            {
              "name": "ButtonAppearance",
              "constName": "buttonAppearances"
            },
            {
              "name": "ButtonSize",
              "constName": "buttonSizes"
            }
          ],
          "interfaces": [
            {
              "name": "ButtonBaseProps",
              "props": [
                {
                  "name": "intent",
                  "type": "ButtonIntent",
                  "optional": true
                },
                {
                  "name": "appearance",
                  "type": "ButtonAppearance",
                  "optional": true
                },
                {
                  "name": "size",
                  "type": "ButtonSize",
                  "optional": true
                },
                {
                  "name": "loading",
                  "type": "boolean",
                  "optional": true
                }
              ]
            }
          ],
          "requiredPicks": [
            {
              "name": "ButtonDefaults",
              "source": "ButtonBaseProps",
              "keys": ["intent", "appearance", "size", "loading"]
            }
          ]
        }
      },
      "style": {
        "from": "packages/components/button/src/button.css",
        "fileName": "button.css"
      },
      "shared": [
        {
          "kind": "recipe",
          "from": "packages/components/button/src/recipe.ts",
          "to": "recipe.ts"
        },
        {
          "kind": "types",
          "to": "types.ts",
          "generate": "types"
        }
      ],
      "files": {
        "react": [
          {
            "kind": "react",
            "from": "packages/components/button/src/react.tsx",
            "to": "button.tsx"
          }
        ],
        "svelte": [
          {
            "kind": "svelte",
            "from": "packages/components/button/src/svelte.svelte",
            "to": "Button.svelte"
          }
        ],
        "vue": [
          {
            "kind": "vue",
            "from": "packages/components/button/src/vue.vue",
            "to": "Button.vue"
          }
        ],
        "astro": [
          {
            "kind": "astro",
            "from": "packages/components/button/src/astro.astro",
            "to": "Button.astro"
          }
        ]
      }
    }
  }
}
